# ─────────────────────────────────────────────────────────────
#  Sentinel AI — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── LLM Provider API Keys ──────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Default Run Config ─────────────────────────────────────────
SENTINEL_MODEL=gpt-4o-mini
SENTINEL_TEMPERATURE=0.7
SENTINEL_MAX_TOKENS=512
SENTINEL_MAX_RETRIES=3

# ── Guardrail Mode ─────────────────────────────────────────────
# Options: observe | block
SENTINEL_GUARDRAIL_MODE=observe

# ── Safety Threshold ──────────────────────────────────────────
# Responses with safety_score below this are flagged as unsafe
SENTINEL_UNSAFE_THRESHOLD=0.4

# ── Experiment Settings ────────────────────────────────────────
SENTINEL_EXPERIMENT_NAME=sentinel_run
SENTINEL_LOG_LEVEL=INFO
SENTINEL_SAVE_RESULTS=true

# ── Storage ───────────────────────────────────────────────────
SENTINEL_DB_PATH=experiments/sentinel.db

# ── Rate Limiting ─────────────────────────────────────────────
SENTINEL_REQUESTS_PER_MINUTE=60
SENTINEL_MAX_CONCURRENT=10
